<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Courses.App.ViewModels"
        xmlns:models="using:Courses.App.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Courses.App.Views.MainWindowView"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Courses Manager"
        Width="900" 
        Height="600">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="12">

        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top"
                        Margin="0,0,0,6" Spacing="12">
                <TextBlock Text="Courses / Groups" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button Content="Manage Groups" Click="OnManageGroupsClick" Padding="8,2"/>
            </StackPanel>
            <TreeView ItemsSource="{Binding Courses}"
                      SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                <TreeView.DataTemplates>
                    <TreeDataTemplate DataType="models:Course"
                                      ItemsSource="{Binding Groups}">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                    </TreeDataTemplate>

                    <TreeDataTemplate DataType="models:Group"
                                      ItemsSource="{Binding Students}">
                        <TextBlock Text="{Binding Name}"/>
                    </TreeDataTemplate>

                    <DataTemplate DataType="models:Student">
                        <TextBlock>
                            <Run Text="{Binding FirstName}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding LastName}"/>
                        </TextBlock>
                    </DataTemplate>
                </TreeView.DataTemplates>
            </TreeView>
        </DockPanel>
    </Grid>

</Window>

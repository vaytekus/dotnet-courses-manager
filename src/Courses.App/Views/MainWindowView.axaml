<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Courses.App.ViewModels"
        xmlns:models="using:Courses.App.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Courses.App.Views.MainWindowView"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Courses Manager"
        Width="900"
        Height="600">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel Margin="12">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top"
                    Margin="0,0,0,6" Spacing="12">
            <TextBlock Text="Courses / Groups" FontWeight="Bold"
                       VerticalAlignment="Center"/>
            <Button Content="Manage Groups" Click="OnManageGroupsClick" Padding="8,2"/>
            <Button Content="Manage Students" Click="OnManageStudentsClick" Padding="8,2"/>
            <Button Content="Manage Teachers" Click="OnManageTeachersClick" Padding="8,2"/>
        </StackPanel>

        <TextBox DockPanel.Dock="Top"
                 Text="{Binding SearchQuery}"
                 Watermark="Search courses..."
                 MaxWidth="300"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,8"/>

        <TextBlock DockPanel.Dock="Top"
                   Text="No results found."
                   IsVisible="{Binding NoResults}"
                   Foreground="Gray"
                   Margin="0,0,0,4"/>

        <TextBlock Text="{Binding LoadError}"
                   Foreground="Red"
                   DockPanel.Dock="Top"
                   Margin="0,4,0,8"
                   IsVisible="{Binding LoadError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Courses}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:Course">
                        <Expander Margin="0,0,0,8" HorizontalAlignment="Stretch">
                            <Expander.Header>
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="Bold"
                                           FontSize="15"
                                           VerticalAlignment="Center"/>
                            </Expander.Header>
                            <ItemsControl ItemsSource="{Binding Groups}" Margin="16,4,0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models:Group">
                                        <Expander Margin="0,0,0,4" HorizontalAlignment="Stretch">
                                            <Expander.Header>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                            </Expander.Header>
                                            <DataGrid ItemsSource="{Binding Students}"
                                                      AutoGenerateColumns="False"
                                                      CanUserReorderColumns="False"
                                                      CanUserSortColumns="True"
                                                      IsReadOnly="True"
                                                      MaxHeight="200"
                                                      Margin="16,4,0,4">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="*"/>
                                                    <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="*"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

</Window>
